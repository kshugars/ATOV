	item(FEAT_SHIPS, item_Barge2) {
property{
        name: string(STR_BT2_NAME);
        introduction_date: date(1952, 06, 1);
        model_life: 40;
        vehicle_life: 30;
        loading_speed: 10;
        cost_factor: 140;
        running_cost_factor: 80;
        speed: 30 km/h;
	ocean_speed_fraction: 0.7;
        cargo_capacity: 360;
        climates_available: ALL_CLIMATES;
        refit_cost: 10;		
	is_refittable: 1;
	refittable_cargo_classes: bitmask(CC_BULK);
	cargo_disallow_refit: [WOOD];
        sprite_id: SPRITE_ID_NEW_SHIP;
	sound_effect: SOUND_DEPARTURE_CARGO_SHIP;
	sound_effect: 	SOUND_BREAKDOWN_TRAIN_SHIP;
		}
	    graphics {
