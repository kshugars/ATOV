/*Barge3*/
	
	template tmpl_Barge3(y) {
    //left_x, upper_y, width, height, offset_x, offset_y
    [ 0,      y,        19,    53,      -9,      -26]
    [ 20,     y,       72,    42,     -72,       -0]
    [ 93,     y,       74,    19,     -46,       -9]
    [ 168,     y,       73,    42,      -0,       -0]
    [ 242,    y,        19,    52,      -9,      -26]
    [ 262,    y,       73,    42,     -73,       -0]
    [ 336,    y,       74,    19,     -37,       -9]
    [ 411,    y,       72,    42,      -0,       -0]
	}
	
