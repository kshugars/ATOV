	item(FEAT_ROADVEHS, item_ACID_1) {
    	property {
        name:                           string(STR_ACID_NAME1);
        climates_available:             ALL_CLIMATES;
        introduction_date:              date(1935,08,30);
        model_life:                     65;
        vehicle_life:                   15;
        cost_factor:                    110;
        running_cost_factor:            60;
        running_cost_base:              RUNNING_COST_ROADVEH;
        sprite_id:                      SPRITE_ID_NEW_ROADVEH;
