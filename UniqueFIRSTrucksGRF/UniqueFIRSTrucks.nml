    [ 144,    y,       21,    16,     -14,        -7]
    [ 185,    y,       28,    12,     -14,        -6]
    [ 224,    y,       21,    16,      -6,        -7]
}
template tmpl_truck2(y) {
    // parameters x, y: coordinates of top-left corner of first sprite
    [ 256,      y,        8,    18,      -3,       -10]
    [ 272,     y,       21,    16,     -14,        -7]
    [ 304,     y,       28,    12,     -14,        -6]
    [ 352,     y,       21,    16,      -6,        -7]
    [ 384,    y,        8,    18,      -3,       -10]
