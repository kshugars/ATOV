	template tmpl_truck1(y) {
    // parameters x, y: coordinates of top-left corner of first sprite
    [ 0,      y,        8,    18,      -3,       -10]
    [ 16,     y,       21,    16,     -14,        -7]
    [ 48,     y,       28,    12,     -14,        -6]
    [ 96,     y,       21,    16,      -6,        -7]
