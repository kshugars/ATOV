	/*-VEHI-*/

template tmpl_VEHI1(y) {
    // parameters x, y: coordinates of top-left corner of first sprite
    [ 0,      y,        8,    24,      -3,       -(10+6)]
    [ 16,     y,       21,    22,     -14,        -(7+6)]
    [ 48,     y,       28,    18,     -14,        -(6+6)]
    [ 96,     y,       21,    22,      -6,        -(7+6)]
    [ 128,    y,        8,    24,      -3,       -(10+6)]
    [ 144,    y,       21,    22,     -14,        -(7+6)]
    [ 185,    y,       28,    18,     -14,        -(6+6)]
    [ 224,    y,       21,    22,      -6,        -(7+6)]
}
template tmpl_VEHI2(y) {
    // parameters x, y: coordinates of top-left corner of first sprite
    [ 256,      y,        8,    24,      -3,       -(10+6)]
    [ 272,     y,       21,    22,     -14,        -(7+6)]
    [ 304,     y,       28,    18,     -14,        -(6+6)]
    [ 352,     y,       21,    22,      -6,        -(7+6)]
    [ 384,    y,        8,    24,      -3,       -(10+6)]
    [ 400,    y,       21,    22,     -14,        -(7+6)]
    [ 441,    y,       28,    18,     -14,        -(6+6)]
    [ 480,    y,       21,    22,      -6,        -(7+6)]
}
template tmpl_VEHI3(y) {
    // parameters x, y: coordinates of top-left corner of first sprite
    [ 512,      y,        8,    24,      -3,       -(10+6)]
    [ 528,     y,       21,    22,     -14,        -(7+6)]
    [ 560,     y,       28,    18,     -14,        -(6+6)]
    [ 608,     y,       21,    22,      -6,        -(7+6)]
    [ 640,    y,        8,    24,      -3,       -(10+6)]
    [ 656,    y,       21,    22,     -14,        -(7+6)]
    [ 697,    y,       28,    18,     -14,        -(6+6)]
    [ 736,    y,       21,    22,      -6,        -(7+6)]
}

