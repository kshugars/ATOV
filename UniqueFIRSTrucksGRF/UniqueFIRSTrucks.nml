    [ 441,    y,       28,    12,     -14,        -6]
    [ 480,    y,       21,    16,      -6,        -7]
}
template tmpl_truck3(y) {
    // parameters x, y: coordinates of top-left corner of first sprite
    [ 512,      y,        8,    18,      -3,       -10]
